<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UI Hierarchy Capture"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Capture Interval (ms):"
        android:textColor="#CCCCCC"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etInterval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="1000"
        android:text="1000"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:background="#1E1E1E"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Enable Accessibility Service"
        android:backgroundTint="#3700B3"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnStartStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Start Capture"
        android:backgroundTint="#03DAC5"
        android:textColor="#000000"
        android:layout_marginBottom="12dp"/>

    <!-- NEW: Run Script button -->
    <Button
        android:id="@+id/btnRunScript"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="▶  Run Script"
        android:backgroundTint="#FF6D00"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: IDLE"
        android:textColor="#03DAC5"
        android:textSize="14sp"
        android:background="#1E1E1E"
        android:padding="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\n📁 Output file:\n/storage/emulated/0/Controller/ui_hierarchy.txt\n\nSteps:\n1. Tap 'Enable Accessibility Service'\n2. Find and enable 'UIHierarchyCapture' in the list\n3. Come back and tap 'Start Capture'\n4. Tap 'Run Script' to execute automation"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:background="#1A1A1A"/>

</LinearLayout>